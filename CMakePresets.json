{
  "version": 4,
  "cmakeMinimumRequired":
  {
    "major": 3,
    "minor": 27,
    "patch": 2
  },
  "configurePresets":
  [
    {
      "name": "Common",
      "description": "ROS2 enabled",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/Build",
      "toolchainFile": "${sourceDir}/CMake/Toolchain.cmake",

      "cacheVariables": {
        "ENABLE_ROS2": "ON",
        "BUILD_LIBCARLA_TESTS": "OFF",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      },
      "hidden": true
    },
    {
      "name": "Development",
      "inherits": "Common",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS" : true
      }
    },
    {
      "name": "Release",
      "inherits": "Common",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "Debug",
      "inherits": "Common",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS" : true
      }
    },
    {
      "name": "Common-CycloneDDS",
      "description": "ROS2 enabled with CycloneDDS",
      "inherits": "Common",
      "cacheVariables": {
        "CARLA_DDS_VENDOR": "CycloneDDS"
      },
      "hidden": true
    },
    {
      "name": "Development-CycloneDDS",
      "inherits": "Common-CycloneDDS",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS" : true
      }
    },
    {
      "name": "Release-CycloneDDS",
      "inherits": "Common-CycloneDDS",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "Debug-CycloneDDS",
      "inherits": "Common-CycloneDDS",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS" : true
      }
    }
  ]
}
