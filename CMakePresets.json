{
  "version": 4,
  "cmakeMinimumRequired":
  {
    "major": 3,
    "minor": 27,
    "patch": 2
  },
  "configurePresets":
  [
    {
      "name": "Common",
      "description": "Ninja generator, Carla custom toolchain, ROS2 enabled",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/Build",
      "toolchainFile": "${sourceDir}/CMake/Toolchain.cmake",

      "cacheVariables": {
        "ENABLE_ROS2": "ON",
        "Python_ROOT_DIR": "/absolute/path/to/python",
        "Python3_ROOT_DIR": "/absolute/path/to/python",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      },
      "hidden": true
    },
    {
      "name": "Development",
      "inherits": "Common",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS" : true
      }
    },
    {
      "name": "Release",
      "inherits": "Common",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "Debug",
      "inherits": "Common",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS" : true
      }
    }
  ]
}
