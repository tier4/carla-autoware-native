# =============================================================================
# CARLA Docker Development Environment Configuration
# =============================================================================
# Copy this file to .env and edit paths for your environment:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Work directory (required) — parent of UE5, CarlaUE5, RGL
# Mounted at the same absolute path inside the container (symlink compatible).
# ---------------------------------------------------------------------------
WORK_PATH=/mnt/dsk0/wk0/CARLA/T4ForkWithRGL

# Subdirectory names within WORK_PATH (change only if non-standard layout)
UE5_SUBDIR=UnrealEngine5_carla
CARLA_SUBDIR=CarlaUE5

# ---------------------------------------------------------------------------
# Optional mounts
# ---------------------------------------------------------------------------
# AWSIM source (for preset reference, extraction scripts)
AWSIM_PATH=/mnt/dsk0/wk0/AWSIM/OSS/AWSIM
# Autoware installation
AUTOWARE_PATH=/mnt/dsk0/wk0/ROS2/humble/AW-OSS/1.7.1/autoware

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------
CLAUDE_CONFIG=~/.claude
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Network mode: "bridge" (default, safe) or "host" (for ROS2 multicast)
# ---------------------------------------------------------------------------
# bridge: Only ports 2000-2002,1985 are exposed. Process isolation from host network.
# host:   Full host network access. Required for ROS2 DDS multicast discovery.
NETWORK_MODE=bridge

# ---------------------------------------------------------------------------
# User ID matching (run: id -u / id -g on host)
# ---------------------------------------------------------------------------
UID=1000
GID=1000
